#define _CRT_SECURE_NO_WARNINGS // VS 보안 경고 방지
#include <stdio.h>
#include <string.h>

int main() {
    char str[100];

    printf("값 입ㄺ : ");
    if (fgets(str, sizeof(str), stdin) == NULL) {
        return -1;
    }
    str[strcspn(str, "\n")] = '\0';

    int length = (int)strlen(str);

    printf("결과 : ");
    for (int i = 0; i < length; i++) {
        if (str[i] >= 'A' && str[i] <= 'Z') {
            printf("%c", str[i] + 32);
        }
        else if (str[i] >= 'a' && str[i] <= 'z') {
            printf("%c", str[i] - 32);
        }
        else {
            printf("%c", str[i]);
        }
    }
    printf("\n");

    return 0;
}
